{
	"name": "ana-app-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"generate:enums": "bun ./scripts/generate-system-enum.ts && bun ./scripts/generate-subfactor-enum.ts && bun ./scripts/generate-factor-enum.ts && bun ./scripts/generate-metric-enum.ts",
		"generate:reference-json": "bun ./scripts/generate-reference-json.ts",
		"validate:reference-json": "bun ./scripts/validate-reference-json.ts",
		"validate:hypotheses-json": "bun ./scripts/validate-hypotheses-json.ts",
		"validate:circlepacking-json": "bun ./scripts/validate-circlepacking-json.ts",
		"generate:input-data": "bun ./scripts/generate-input-data.ts",
		"data:refresh": "bun run generate:enums && bun run generate:reference-json && bun run validate:reference-json && bun run validate:hypotheses-json && bun run validate:circlepacking-json && bun run generate:input-data",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^9.39.4",
		"@flowbite-svelte-plugins/datatable": "^0.4.1",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/d3": "^7.4.3",
		"@types/d3-array": "^3.2.2",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-zoom": "^3.0.8",
		"@types/node": "^24.12.2",
		"clsx": "^2.1.1",
		"daisyui": "^5.5.19",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-headless-table": "^0.18.3",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^7.3.2",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@colbymchenry/codegraph": "^0.7.3",
		"@fontsource/gloria-hallelujah": "^5.2.8",
		"@fontsource/noto-sans": "^5.2.10",
		"@fontsource/roboto-condensed": "^5.2.8",
		"@protobi/exceljs": "^4.4.0-protobi.9",
		"@tanstack/table-core": "^8.21.3",
		"@tidyjs/tidy": "^2.6.1",
		"@turf/buffer": "^7.3.5",
		"@turf/dissolve": "^7.3.5",
		"@turf/polygon-to-line": "^7.3.5",
		"@turf/simplify": "^7.3.5",
		"@turf/union": "^7.3.5",
		"@types/papaparse": "^5.5.2",
		"bun-plugin-tailwind": "^0.1.2",
		"d3": "^7.9.0",
		"d3-array": "^3.2.4",
		"d3-axis": "^3.0.0",
		"d3-force": "^3.0.0",
		"d3-geo": "^3.1.1",
		"d3-scale": "^4.0.2",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"d3-zoom": "^3.0.0",
		"fflate": "^0.8.2",
		"gh-pages": "^6.3.0",
		"i18n-iso-countries": "^7.14.0",
		"papaparse": "^5.5.3",
		"svelteplot": "^0.12.0",
		"zod": "^4.4.3"
	}
}
